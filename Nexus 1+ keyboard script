-- Constant Speed Movement Logic
local function travelTo(targetPosition)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local speed = 500 -- Studs per second
    local fps = 60
    local waitTime = 1 / fps
    local stepSize = speed * waitTime -- Distances traveled per frame at 30 speed

    local currentPos = hrp.Position
    local distance = (targetPosition - currentPos).Magnitude
    local direction = (targetPosition - currentPos).Unit
    local steps = math.floor(distance / stepSize)

    for i = 1, steps do
        if not hrp or not hrp.Parent then break end
        hrp.CFrame = CFrame.new(currentPos + (direction * (i * stepSize)))
        task.wait(waitTime)
    end
    -- Snap exactly to the final target
    hrp.CFrame = CFrame.new(targetPosition)
end

