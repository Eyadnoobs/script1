local function getFlashTargetDestination()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp or not camera then return nil end
    
    local startPos = hrp.Position
    local lookDirection = camera.CFrame.LookVector.Unit
    local rawTargetPos = startPos + (lookDirection * FLASH_DISTANCE)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {character, previewClone}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    
    local firstCheck = workspace:Raycast(startPos, lookDirection * FLASH_DISTANCE, raycastParams)
    local validatedTargetPos = rawTargetPos
    
    if firstCheck then
        local wallHitPos = firstCheck.Position
        local thicknessCheckStart = wallHitPos + (lookDirection * 3.5)
        local thicknessCheck = workspace:Raycast(thicknessCheckStart, -lookDirection * 4, raycastParams)
        
        if thicknessCheck then
            local wallBackPos = thicknessCheck.Position
            local wallThickness = (wallHitPos - wallBackPos).Magnitude
            if wallThickness <= 5.1 then
                validatedTargetPos = wallBackPos + (lookDirection * 1.5)
            else
                validatedTargetPos = wallHitPos - (lookDirection * 1.5)
            end
        else
            validatedTargetPos = thicknessCheckStart
        end
    end
    
    local floorResult = workspace:Raycast(validatedTargetPos + Vector3.new(0, 5, 0), Vector3.new(0, -20, 0), raycastParams)
    if floorResult then return floorResult.Position + Vector3.new(0, 3, 0) end
    return Vector3.new(validatedTargetPos.X, startPos.Y, validatedTargetPos.Z)
end

local function cleanTargetVisuals()
    if previewClone then previewClone:Destroy() previewClone = nil end
    for _, item in ipairs(previewVfxItems) do
        if item then item:Destroy() end
    end
    previewVfxItems = {}
end

local function createTargetVisuals()
    cleanTargetVisuals()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not character or not hrp then return end
    
    character.Archivable = true
    previewClone = character:Clone()
    character.Archivable = false
    previewClone.Name = "FlashTeleportPreviewClone"
    
    for _, obj in ipairs(previewClone:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.Anchored = true
            obj.CanCollide = false 
            obj.CanTouch = false   
            obj.CanQuery = false   
            obj.CastShadow = false
            obj.Transparency = 0.6
            obj.Color = Color3.fromRGB(0, 215, 255)
            obj.Material = Enum.Material.ForceField 
        elseif obj:IsA("Decal") then 
            obj.Texture = "" 
        elseif obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("HumanoidDescription") then 
            obj:Destroy() 
        end
    end
    
    local cloneHrp = previewClone:FindFirstChild("HumanoidRootPart")
    if cloneHrp then
        -- Particle Emitter FX attached directly inside the target clone root
        local emitter = Instance.new("ParticleEmitter")
        emitter.Color = ColorSequence.new(Color3.fromRGB(0, 235, 255))
        emitter.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 1.2), NumberSequenceKeypoint.new(1, 0)})
        emitter.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.2), NumberSequenceKeypoint.new(1, 1)})
        emitter.Lifetime = NumberRange.new(0.4, 0.8)
        emitter.Rate = 35
        emitter.Speed = NumberRange.new(2, 5)
        emitter.SpreadAngle = Vector2.new(360, 360)
        emitter.Texture = "rbxassetid://242293441" 
        emitter.Parent = cloneHrp
        
        local groundRing = Instance.new("Part")
        groundRing.Name = "PreviewGroundRing"
        groundRing.Shape = Enum.PartType.Cylinder
        groundRing.Size = Vector3.new(0.4, 4.5, 4.5)
        groundRing.Color = Color3.fromRGB(0, 215, 255)
        groundRing.Material = Enum.Material.Neon
        groundRing.Transparency = 0.75
        groundRing.Anchored = true
        groundRing.CanCollide = false
        groundRing.CanTouch = false
        groundRing.CanQuery = false
        groundRing.Parent = workspace
        
        table.insert(previewVfxItems, groundRing)
    end
    
    if previewClone:FindFirstChildOfClass("Humanoid") then 
        previewClone:FindFirstChildOfClass("Humanoid").DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None 
    end
    previewClone.Parent = workspace
end

