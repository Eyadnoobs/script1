    targetPlaceId = tonumber(targetPlaceId)

    if privateLinkCode then
        JoinerStatus.Text = "Injecting Token... Swap same game if blocked."
        task.spawn(function()
            local success, err = pcall(function()
                local options = Instance.new("TeleportOptions")
                options:SetTeleportData({["PrivateServerLinkCode"] = privateLinkCode})
                return TeleportService:TeleportAsync(targetPlaceId, {player}, options)
            end)
            if not success then
                pcall(function() TeleportService:TeleportToPrivateServer(targetPlaceId, privateLinkCode, {player}) end)
            end
        end)
    else
        JoinerStatus.Text = "Rerouting to public map instance..."
        pcall(function() TeleportService:Teleport(targetPlaceId, player) end)
    end
end)

