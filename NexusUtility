local function executeFlashBlink()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local targetPosition = getFlashTargetDestination()
        if targetPosition then
            local originalPosition = hrp.Position
            triggerScreenFlashEffect()
            createElectricSparkFX(originalPosition, targetPosition)
            hrp.CFrame = CFrame.lookAt(Vector3.new(), hrp.CFrame.LookVector * Vector3.new(1, 0, 1)) + targetPosition
        end
    end
end

