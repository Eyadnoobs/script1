local function createElectricSparkFX(startPos, endPos)
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://126172750038425" 
    sound.Volume = 3.0
    sound.PlayOnRemove = true
    sound.Parent = workspace
    sound:Destroy()

    local function spawnSparkPoint(pos)
        local part = Instance.new("Part", workspace)
        part.Size = Vector3.new(2, 2, 2)
        part.Position = pos
        part.Anchored = true
        part.CanCollide = false
        part.CanTouch = false
        part.CanQuery = false
        part.Transparency = 1 
        part.Color = Color3.fromRGB(255, 215, 0)
        part.Material = Enum.Material.Neon

        local box = Instance.new("SelectionBox", part)
        box.Color3 = Color3.fromRGB(255, 235, 50)
        box.Adornee = part
        local tween = TweenService:Create(part, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Size = Vector3.new(0,0,0)})
        tween:Play()
        tween.Completed:Connect(function() part:Destroy() end)
    end

    spawnSparkPoint(startPos)
    spawnSparkPoint(endPos)

    local beamPart = Instance.new("Part", workspace)
    beamPart.Anchored = true
    beamPart.CanCollide = false
    beamPart.CanTouch = false
    beamPart.CanQuery = false
    beamPart.Material = Enum.Material.Neon
    beamPart.Color = Color3.fromRGB(255, 235, 50)
    beamPart.Size = Vector3.new(0.4, 0.4, (startPos - endPos).Magnitude)
    beamPart.CFrame = CFrame.lookAt(startPos, endPos) * CFrame.new(0, 0, -beamPart.Size.Z/2)

    local beamTween = TweenService:Create(beamPart, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {Size = Vector3.new(0, 0, beamPart.Size.Z), Transparency = 1})
    beamTween:Play()
    beamTween.Completed:Connect(function() beamPart:Destroy() end)
end

