end

local function loadSettings()
    if readfile and isfile and isfile(settingsFile) then
        local success, content = pcall(function() return readfile(settingsFile) end)
        if success and content then
            local decodedSuccess, decodedData = pcall(function() return HttpService:JSONDecode(content) end)
