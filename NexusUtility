local function updateFOVSlider(inputPosition)
    local percentage = math.clamp((inputPosition.X - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
    SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
    settingsData.customFOV = math.floor(minFOV + (percentage * (maxFOV - minFOV)))
    SliderValue.Text = tostring(settingsData.customFOV); saveSettings()
end
