-- ================= DATA TRANSMISSION LOGIC =================
local isSending = false

SendButton.MouseButton1Click:Connect(function()
    local inputMessage = TextBox.Text
    
    -- Ensure the message has content and the script isn't currently waiting on a request
    if inputMessage == "" or isSending then return end
    if DISCORD_WEBHOOK_URL == "YOUR_DISCORD_WEBHOOK_URL_HERE" then
        SendButton.Text = "⚠️ Config Missing: Webhook URL required"
        task.delay(3, function() SendButton.Text = "📤 TRANSMIT TO DISCORD" end)
        return
    end
    
    isSending = true
    SendButton.Text = "⏳ Serializing Payload..."
    SendButton.BackgroundColor3 = Color3.fromRGB(60, 70, 170)
    
    -- Constructing a standard webhook payload dictionary
    local payloadData = {
        ["username"] = "Nexus System Logger",
        ["content"] = ("**[Log Event Details]**\n**User:** %s\n**Message:** %s"):format(player.Name, inputMessage)
    }
    
    -- Safely process the HTTP POST request asynchronously 
    task.spawn(function()
        local requestFunc = (syn and syn.request) or request or http_request or (http and http.request)
        
        if requestFunc then
            local success, response = pcall(function()
                return requestFunc({
                    Url = DISCORD_WEBHOOK_URL,
                    Method = "POST",
                    Headers = {
                        ["Content-Type"] = "application/json"
                    },
                    Body = HttpService:JSONEncode(payloadData)
                })
            end)
            
            if success then
                SendButton.Text = "✅ Sent"
                SendButton.BackgroundColor3 = Color3.fromRGB(45, 175, 90)
                TextBox.Text = "" -- Clear out data field on completion
            else
                SendButton.Text = "❌ REQUEST FAILED"
                SendButton.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
            end
        else
            SendButton.Text = "❌ Executor Missing Request Support"
            SendButton.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
        end
        
        -- Reset control flags back to baseline status
        task.wait(3)
        SendButton.Text = "📤 TRANSMIT TO DISCORD"
        SendButton.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
        isSending = false
    end)
end)

-- Draggable UI layout helper framework
local function setupDraggable(targetFrame, dragSurface)
    local dragging, dragInput, dragStart, startPos
    dragSurface.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = targetFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            targetFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
end
setupDraggable(MainFrame, Header)
